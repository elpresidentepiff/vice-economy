# Supabase
SUPABASE_URL=https://your-project-ref.supabase.co
SUPABASE_ANON_KEY=sb_publishable_or_legacy_anon_key
SUPABASE_SERVICE_ROLE_KEY=sb_secret_or_legacy_service_role_key

# Future Railway economy engine
TICK_SECRET=replace-with-long-random-secret
PORT=3000
MARKET_DAMPING=0.05
NODE_ENV=development

# Optional deployed-function smoke test
TEST_PLAYER_EMAIL=test-player@example.com
TEST_PLAYER_PASSWORD=replace-with-test-password
TEST_BUSINESS_ID=00000000-0000-0000-0000-000000000000
ECONOMY_ENGINE_URL=http://localhost:3000
RUN_MUTATING_CRYPTO_TESTS=false
CRYPTO_TEST_SEED_CASH=false
RUN_MUTATING_POLICE_TESTS=false
POLICE_TEST_SEED_CASH=false
POLICE_TEST_DISTRICT_ID=port
RUN_MUTATING_AGENT_DIALOGUE_TESTS=false

# Optional agent dialogue provider. Defaults to local deterministic dialogue.
AGENT_DIALOGUE_PROVIDER=local
OPENAI_API_KEY=
OPENAI_MODEL=gpt-5.2
